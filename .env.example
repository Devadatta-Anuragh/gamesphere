# Copy to apps/api/.env (or export) for local development.

NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Mongo single-node replica set (see docker-compose.dev.yml)
MONGO_URI=mongodb://localhost:27017/gamesphere?replicaSet=rs0

# Redis (host port 6380 -> container 6379, see docker-compose.dev.yml)
REDIS_URL=redis://localhost:6380

# Auth
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:3000

# Game economy
DEFAULT_RAKE_BPS=1000        # 10.00% rake, expressed in basis points
SIGNUP_BONUS_MINOR=50000     # ₦500.00 joining bonus, in minor units (kobo)
TURN_TIMEOUT_MS=15000        # per-turn server-enforced timeout
DISCONNECT_GRACE_MS=30000    # grace before a disconnected player forfeits
