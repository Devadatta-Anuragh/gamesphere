{
  "name": "gamesphere",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "GameSphere — real-money multiplayer Ludo backend (portfolio)",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "dev:api": "pnpm --filter @gamesphere/api dev",
    "dev:web": "pnpm --filter @gamesphere/web dev",
    "build:web": "pnpm --filter @gamesphere/web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
